<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Theme: 全屏沉浸式暗色主题 -->
    <style name="AppTheme" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="colorPrimary">@color/gc_primary</item>
        <item name="colorPrimaryVariant">@color/gc_surface</item>
        <item name="colorOnPrimary">@color/gc_background</item>
        <item name="colorSecondary">@color/gc_accent</item>
        <item name="android:windowBackground">@color/gc_background</item>
    </style>

    <!-- 模式选择器文字样式 -->
    <style name="ModeSelectorText">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/gc_mode_unselected</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="ModeSelectorText.Selected">
        <item name="android:textColor">@color/gc_mode_selected</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- 顶部控制按钮 -->
    <style name="TopControlButton">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:padding">10dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:tint">@color/gc_primary</item>
        <item name="android:scaleType">centerInside</item>
    </style>

    <!-- 设置项文本 -->
    <style name="SettingsLabel">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/gc_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
</resources>